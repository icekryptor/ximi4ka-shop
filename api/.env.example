# ==============================================================================
# API environment variables
# ==============================================================================
# Copy this file to .env (or .env.local) and fill in real values.
# Never commit .env files — only .env.example is tracked.

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------
# Port the Express server listens on. Default: 3001.
PORT=3001

# ------------------------------------------------------------------------------
# Database (Postgres / Supabase)
# ------------------------------------------------------------------------------
# Connection string. In dev, points at the docker-compose Postgres on :5433.
# In prod, a Supabase connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/ximi4ka_shop

# ------------------------------------------------------------------------------
# Admin auth
# ------------------------------------------------------------------------------
# Random 32+ char secret for signing admin session cookies. Rotate on compromise.
# Generate: `openssl rand -hex 32`
ADMIN_SESSION_SECRET=replace-me-with-32-plus-random-chars

# ------------------------------------------------------------------------------
# ERP integration (outbound: shop → ERP)
# ------------------------------------------------------------------------------
# URL of the ERP's inbound-orders endpoint.
ERP_INBOUND_URL=https://erp.ximi4ka.ru/api/internal/orders/inbound
# Shared secret; must match the value set on the ERP side.
ERP_SHARED_SECRET=replace-me-shared-with-erp

# ------------------------------------------------------------------------------
# Payments: Yandex Pay
# ------------------------------------------------------------------------------
# Merchant API credentials. Use sandbox values in dev, production in prod.
YANDEX_PAY_API_KEY=your-yandex-pay-api-key
YANDEX_PAY_SECRET=your-yandex-pay-secret

# ------------------------------------------------------------------------------
# Storage: Supabase
# ------------------------------------------------------------------------------
# Public storage base URL (e.g. https://<project>.supabase.co/storage/v1).
SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1
# Service-role key; server-side only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------------------------------------------
# Observability
# ------------------------------------------------------------------------------
# Sentry DSN. Leave blank in dev to disable error reporting.
SENTRY_DSN=
