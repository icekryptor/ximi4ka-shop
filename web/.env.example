# ==============================================================================
# Web (Next.js) environment variables
# ==============================================================================
# Copy this file to .env.local and fill in real values.
# NEXT_PUBLIC_* variables are bundled into the client — never put secrets here.

# ------------------------------------------------------------------------------
# API
# ------------------------------------------------------------------------------
# Base URL of the shop API. In dev: http://localhost:3001. In prod: the Railway
# domain of the api service (e.g. https://ximi4ka-shop-api-production.up.railway.app);
# a custom domain is optional.
NEXT_PUBLIC_API_URL=http://localhost:3001

# ------------------------------------------------------------------------------
# Site
# ------------------------------------------------------------------------------
# Canonical public URL. Used for og:url, canonical tags, sitemap, etc.
# In prod: https://new.ximi4ka.ru.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Analytics (optional; leave blank to disable)
# ------------------------------------------------------------------------------
# Яндекс.Метрика counter ID.
NEXT_PUBLIC_METRIKA_ID=
# Google Analytics 4 measurement ID (G-XXXXXXXXXX).
NEXT_PUBLIC_GA4_ID=
